generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMMUTER
  PARTNER
  STAFF
  ADMIN
}

enum VehicleType {
  BIKE
  CAR
}

enum PartnerStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum LotType {
  HOUSEHOLD
  COMMERCIAL
}

enum CheckInMode {
  STAFF
  AUTOMATED
}

enum LotStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ClosedBy {
  STAFF
  AUTOMATED
  SYSTEM
}

enum PaymentMethod {
  CASH
}

enum OtpProvider {
  MOCK
  ESMS
  TWILIO
}

model User {
  id        String    @id @default(uuid())
  phone     String    @unique
  name      String
  cccd      String?
  fcmToken  String?
  role      Role      @default(COMMUTER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicles  Vehicle[]
  sessions  Session[]
  tokens    RefreshToken[]
}

model Vehicle {
  id        String      @id @default(uuid())
  userId    String
  plate     String
  type      VehicleType
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@unique([userId, plate])
  @@index([plate])
}

model Partner {
  id          String        @id @default(uuid())
  ownerName   String
  phone       String        @unique
  cccd        String
  bankAccount String?
  status      PartnerStatus @default(PENDING)
  verifiedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lots        Lot[]
  staff       Staff[]
}

model Staff {
  id        String   @id @default(uuid())
  partnerId String
  phone     String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  lots      StaffLot[]
}

model StaffLot {
  staffId String
  lotId   String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  lot     Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@id([staffId, lotId])
}

model Lot {
  id             String      @id @default(uuid())
  partnerId      String
  name           String
  address        String
  lat            Float
  lng            Float
  lotType        LotType
  totalCapacity  Int
  activeSessions Int         @default(0)
  priceBike      Int
  priceCar       Int
  schedule       Json
  checkInMode    CheckInMode
  status         LotStatus   @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  partner        Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  sessions       Session[]
  staff          StaffLot[]
  adjustments    CapacityAdjustment[]

  @@index([lat, lng])
  @@index([status])
}

model Session {
  id            String        @id @default(uuid())
  userId        String
  vehicleId     String
  lotId         String
  checkInTime   DateTime      @default(now())
  checkOutTime  DateTime?
  durationMin   Int?
  fee           Int?
  status        SessionStatus @default(ACTIVE)
  closedBy      ClosedBy?
  paymentMethod PaymentMethod?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id])
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  lot           Lot           @relation(fields: [lotId], references: [id])

  @@index([userId, status])
  @@index([lotId, status])
  @@index([vehicleId, status])
}

model OtpCode {
  id        String      @id @default(uuid())
  phone     String
  codeHash  String
  provider  OtpProvider
  attempts  Int         @default(0)
  expiresAt DateTime
  used      Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([phone, used])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CapacityAdjustment {
  id        String   @id @default(uuid())
  lotId     String
  delta     Int
  reason    String
  staffId   String?
  createdAt DateTime @default(now())
  lot       Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId, createdAt])
}
